{
  "name": "atlas-of-answers",
  "private": true,
  "version": "0.6.5",
  "type": "module",
  "scripts": {
    "prepare": "npm run hooks:install",
    "dev": "vite",
    "assets:og": "node scripts/generate-og-card.mjs",
    "check": "npm run lint && npm run test:unit && npm run build",
    "check:fast": "npm run lint && npm run test:changed && npm run build",
    "build": "npm run build:sitemap && tsc -b && vite build && npm run build:verify-cache",
    "build:pages:fresh": "node scripts/build-pages-fresh.mjs",
    "build:verify-cache": "node scripts/verify-cache-artifacts.mjs",
    "docs:check": "node scripts/check-docs-sync.mjs --staged",
    "docs:check:ci": "node scripts/check-docs-sync.mjs",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:pages:fresh": "node scripts/run-local-pages-preview.mjs",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:unit:changed": "node scripts/run-changed-tests.mjs unit",
    "test:watch": "vitest",
    "test:changed": "node scripts/run-changed-tests.mjs all",
    "test:e2e": "npm run test:e2e:full",
    "test:e2e:smoke": "playwright test tests/smoke.spec.ts",
    "test:e2e:full": "playwright test",
    "test:e2e:offline": "playwright test --config=playwright.offline.config.ts",
    "cocktails:fetch": "node scripts/cocktail-catalog-cli.mjs",
    "songs:check": "node scripts/artist-catalog-cli.mjs check",
    "songs:add": "node scripts/artist-catalog-cli.mjs add",
    "songs:bulk": "node scripts/artist-catalog-cli.mjs bulk",
    "songs:bulk-import": "node scripts/artist-catalog-cli.mjs bulk-import",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major",
    "build:sitemap": "node scripts/generate-sitemap.mjs"
  },
  "dependencies": {
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/source-sans-3": "^5.2.9",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.105.4",
    "@svg-maps/usa": "^2.0.0",
    "@svg-maps/world": "^2.0.0",
    "@types/topojson-client": "^3.1.5",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-geo": "^3.1.1",
    "flag-icons": "^7.5.0",
    "lucide-react": "^1.14.0",
    "posthog-js": "^1.372.10",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.15.0",
    "svg-path-bbox": "^2.1.0",
    "tailwind-merge": "^3.5.0",
    "topojson-client": "^3.1.0",
    "us-atlas": "^3.0.1",
    "world-atlas": "^2.0.2",
    "world-countries": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.2.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.5"
  }
}
